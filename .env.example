# ExpiredDomains.net asks for "Username" on login. Use the account username if email login fails.
EXPIREDDOMAINS_LOGIN=
EXPIREDDOMAINS_PASSWORD=

# Optional. Used only by: python main.py --signup
EXPIREDDOMAINS_REGISTER_USERNAME=
EXPIREDDOMAINS_REGISTER_EMAIL=
EXPIREDDOMAINS_REGISTER_PASSWORD=

# Scraper behavior
SCRAPE_URL=https://member.expireddomains.net/domains/combinedexpired/
SCRAPE_INTERVAL_SECONDS=60
REQUEST_GAP_SECONDS=50
SCRAPE_PAGES_PER_RUN=1
SCRAPE_START_PAGE=1
SCRAPE_DAILY_PAGE_LIMIT=51
SCRAPE_CURSOR_CYCLE_SECONDS=86400
SCRAPE_ADVANCE_PAGES=true
SCRAPE_PAGE_CURSOR_FILE=page_cursor.json
SCRAPE_TARGET_TOTAL_DOMAINS=1000
SCRAPE_DOMAINS_PER_PAGE=200
SCRAPE_TRUST_FLOW_MIN=1
SCRAPE_TLD_FILTER_MODE=exclude
APPLY_SITE_FILTERS=false
SITE_TLD_BLOCKLIST=
SCRAPE_ONLY_AVAILABLE=false
SCRAPE_HEADLESS=true
EXPIREDDOMAINS_AUTO_LOGIN=false

# Output files
OUTPUT_JSON=result.json
OUTPUT_JSONL=domains.jsonl
EXPORT_DOMAINS_ONLY=false
EXPORT_CSV_ENABLED=false
EXPORT_DOMAINS_FILE=expired_domains_export.csv
SEEN_FILE=seen_domains.json
STATE_DIR=.browser-state

MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=expired_domains_db
MONGO_COLLECTION=expired_domains
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change-this-api-key

# Website SEO Checker workflow
WSC_COLLECTION=website_seo_checker_results
WSC_BATCH_SIZE=50
WSC_TIMEOUT_MS=180000
WSC_HEADLESS=false
WSC_FORCE=false
WSC_URL=https://websiteseochecker.com/pro-service/
WSC_AUTO_AFTER_EXPORT=false
WSC_AUTO_BATCH_SIZE=50
WSC_AUTO_MAX_BATCHES=4

# Nawala HTTP API check after Website SEO Checker
NAWALA_AUTO_AFTER_WSC=true
NAWALA_API_URL=https://ucantseeme.200m.website/api/check
NAWALA_API_KEY=
NAWALA_COLLECTION=domain_nawala_checks
NAWALA_FINAL_COLLECTION=website_seo_checker_nawala_results
NAWALA_CHUNK_SIZE=200
NAWALA_API_TIMEOUT_SECONDS=60

# AdsPower browser profile. Use the AdsPower profile user_id, not the UI row/custom number.
ADSPOWER_ENABLED=false
ADSPOWER_API_URL=http://127.0.0.1:51441
ADSPOWER_API_KEY=
ADSPOWER_USER_ID=
ADSPOWER_PROFILE_NAME=expired domain
